# Use either MONGO_URI or DB_URI.
MONGO_URI=mongodb://127.0.0.1:27017/uniconnect
# DB_URI=mongodb://127.0.0.1:27017/uniconnect

PORT=5000
JWT_SECRET=replace_with_strong_secret
NODE_ENV=development

# Optional: auto-seed up to 4 admin accounts on backend startup
# ADMIN1_NAME=Admin One
# ADMIN1_EMAIL=admin1@example.com
# ADMIN1_PASSWORD=replace_with_strong_password
# ADMIN2_NAME=Admin Two
# ADMIN2_EMAIL=admin2@example.com
# ADMIN2_PASSWORD=replace_with_strong_password
# ADMIN3_NAME=Admin Three
# ADMIN3_EMAIL=admin3@example.com
# ADMIN3_PASSWORD=replace_with_strong_password
# ADMIN4_NAME=Admin Four
# ADMIN4_EMAIL=admin4@example.com
# ADMIN4_PASSWORD=replace_with_strong_password
